{
    "md013": {
        "line_length": 150,
        "code_blocks": false
    },
    // Multiple headings with the same content
        "md024": {
        "siblings_only": true
    },
    // Inline HTML
    "md033": {
        "allowed_elements": ["br", "details", "summary"]
    },
    //  Fenced code blocks should have a language specified
    "md040": false,
    "md046": false
}